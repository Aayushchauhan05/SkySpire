        {
          "id": "chapter_001",
          "order": 1,
          "level": "Pre-A1",
          "title": "The French Alphabet",
          "slug": "french-alphabet",
          "summary": "Learn the 26 letters of the French alphabet and the 5 critical accent marks.",
          "tags": ["alphabet", "accents", "basics"],
          "dependsOn": [],
          "unlocks": [2, 3],
          "sections": [
            {
              "id": "section_001_01",
              "sectionNumber": 1,
              "title": "The 26 Letters",
              "content": "The French alphabet uses the same Latin letters as English, but the names of the letters differ. For example, 'A' is 'ah', 'E' is 'euh', and 'G' is 'zhay'."
            },
            {
              "id": "section_001_02",
              "sectionNumber": 2,
              "title": "The Five Accents",
              "content": "French uses: l'accent aigu (é), grave (è), circonflexe (ê), tréma (ë), and the cédille (ç)."
            }
          ],
          "examples": [
            { "french": "École", "english": "School", "phonetics": "[e.kɔl]" },
            { "french": "Garçon", "english": "Boy", "phonetics": "[ɡaʁ.sɔ̃]" }
          ],
          "quiz": {
            "questions": [
              {
                "type": "multiple_choice",
                "question": "Which accent mark is used in 'ç'?",
                "options": ["Aigu", "Grave", "Cédille"],
                "correctAnswer": "Cédille"
              }
            ]
          }
        },
        {
