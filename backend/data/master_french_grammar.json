      "levelName": "Elementary — Expressing the Past and Future",
      "totalTopics": 20,
      "chapters": [
        {
          "id": "chapter_041",
          "order": 41,
          "level": "A2",
          "title": "Passé Composé with Avoir",
          "slug": "pc-avoir",
          "summary": "The standard past tense for completed actions using the auxiliary 'avoir'.",
          "dependsOn": [15, 30],
          "unlocks": [42, 46],
          "sections": [
            {
              "id": "sec_041_1",
              "sectionNumber": 1,
              "title": "Formation",
              "content": "Formed by using the present tense of 'avoir' + the past participle. For -ER verbs, replace -er with -é. For -IR, use -i. For -RE, use -u."
            }
          ],
          "examples": [
            { "french": "J'ai mangé une pomme.", "english": "I ate an apple.", "phonetics": "[ʒe mɑ̃.ʒe yn pɔm]" },
            { "french": "Il a fini ses devoirs.", "english": "He finished his homework.", "phonetics": "[il a fi.ni se də.vwaʁ]" }
          ],
          "quiz": {
            "questions": [
              {
                "type": "multiple_choice",
                "question": "What is the past participle of 'Vendre'?",
                "options": ["Vendu", "Vendi", "Vende"],
                "correctAnswer": "Vendu"
              }
            ]
          }
        },
        {
          "id": "chapter_042",
          "order": 42,
          "level": "A2",
          "title": "Passé Composé with Être",
          "slug": "pc-etre",
          "summary": "Motion and change-of-state verbs that use 'être' as an auxiliary.",
          "dependsOn": [14, 41],
          "unlocks": [43, 46],
          "sections": [
            {
              "id": "sec_042_1",
              "sectionNumber": 1,
              "title": "House of Être",
              "content": "Verbs like Aller, Venir, Entrer, Sortir, Rester, and Tomber use 'être'. Remember the acronym DR MRS VANDERTRAMP."
            }
          ],
          "examples": [
            { "french": "Elle est allée au cinéma.", "english": "She went to the cinema.", "phonetics": "[ɛ.lɛ ta.le o si.ne.ma]" }
          ],
          "quiz": {
            "questions": [
              {
                "type": "multiple_choice",
                "question": "Which auxiliary does 'Partir' use?",
                "options": ["Avoir", "Être"],
                "correctAnswer": "Être"
              }
            ]
          }
        },
        {
          "id": "chapter_044",
          "order": 44,
          "level": "A2",
          "title": "Reflexive Verbs in the Past",
          "slug": "reflexive-past",
          "summary": "How to conjugate pronominal verbs like 'se lever' in the past tense.",
          "dependsOn": [42],
          "sections": [
            { "id": "sec_044_1", "title": "Pronoun Placement", "content": "The reflexive pronoun goes before the auxiliary 'être'. Example: Je ME suis lavé." }
          ],
          "examples": [
            { "french": "Nous nous sommes réveillés.", "english": "We woke up.", "phonetics": "[nu nu sɔm ʁe.ve.je]" }
          ]
        },
        {
          "id": "chapter_045",
          "order": 45,
          "level": "A2",
          "title": "L'Imparfait",
          "slug": "imparfait",
          "summary": "The descriptive past used for habits, weather, and states of being.",
          "dependsOn": [16],
          "unlocks": [46],
          "sections": [
            { "id": "sec_045_1", "title": "Formation", "content": "Take the 'nous' form of the present tense, drop -ons, and add: -ais, -ais, -ait, -ions, -iez, -aient." }
          ],
          "examples": [
            { "french": "Quand j'étais petit...", "english": "When I was little...", "phonetics": "[kɑ̃ ʒe.tɛ pə.ti]" }
          ]
        },
        {
          "id": "chapter_046",
          "order": 46,
          "level": "A2",
          "title": "PC vs Imparfait",
          "slug": "pc-vs-imparfait",
          "summary": "The ultimate guide to choosing between the two main past tenses.",
          "dependsOn": [41, 45],
          "sections": [
            { "id": "sec_046_1", "title": "The Rule", "content": "Passé Composé is for specific, finished actions. Imparfait is for background, ongoing actions, or descriptions." }
          ]
        },
        {
          "id": "chapter_047",
          "order": 47,
          "level": "A2",
          "title": "Direct Object Pronouns (COD)",
          "slug": "cod-pronouns",
          "summary": "Me, Te, Le, La, Nous, Vous, Les.",
          "sections": [
            { "id": "sec_047_1", "title": "Usage", "content": "They replace a direct object noun to avoid repetition. 'Je mange la pomme' -> 'Je la mange'." }
          ]
        },
        {
          "id": "chapter_049",
          "order": 49,
          "level": "A2",
          "title": "Pronoun Y",
          "slug": "pronoun-y",
          "summary": "Replacing 'à' + place or 'à' + thing.",
          "sections": [
            { "id": "sec_049_1", "title": "Usage", "content": "Y typically means 'there'. 'Tu vas à Paris?' -> 'J'y vais'." }
          ]
        },
        {
          "id": "chapter_050",
          "order": 50,
          "level": "A2",
          "title": "Pronoun EN",
          "slug": "pronoun-en",
          "summary": "Replacing 'de' + noun or quantities.",
          "sections": [
            { "id": "sec_050_1", "title": "Usage", "content": "EN typically means 'some' or 'of it'. 'Tu veux du café?' -> 'J'en veux'." }
          ]
        },
        {
          "id": "chapter_052",
          "order": 52,
          "level": "A2",
          "title": "Le Futur Simple",
          "slug": "futur-simple",
          "summary": "The formal future tense (I will).",
          "dependsOn": [30],
          "sections": [
            { "id": "sec_052_1", "title": "Formation", "content": "Usually the full infinitive + endings: -ai, -as, -a, -ons, -ez, -ont." }
          ],
          "examples": [
            { "french": "Je partirai demain.", "english": "I will leave tomorrow.", "phonetics": "[ʒə paʁ.ti.ʁe də.mɛ̃]" }
          ]
        }
      ]
